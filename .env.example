# =============================================
# Claude Code Docker 环境变量模板
# 复制为 .env 并填入你的实际值
# =============================================

# ---- 必填 ----
# API 地址（MiniMax 国内版 / 海外版）
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic

# API 认证（MiniMax 国内版用 AUTH_TOKEN，海外版用 API_KEY）
ANTHROPIC_AUTH_TOKEN=sk-your-api-key-here

# ---- 可选 ----
# 默认模型（MiniMax-M2.7 / MiniMax-M3）
CLAUDE_MODEL=MiniMax-M2.7

# 权限模式（default / acceptEdits / bypassPermissions / plan）
PERMISSION_MODE=acceptEdits

# API 超时（毫秒），600000 = 10 分钟
API_TIMEOUT_MS=600000
